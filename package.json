{
  "name": "@aditya-sharma-salescode/reports-ui",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "version": "1.0.20",
  "description": "Plug-and-play reports UI module — config in, full reports flow out.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:app": "vite build --config vite.config.app.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "@fortawesome/free-solid-svg-icons": "^6 || ^7",
    "@fortawesome/react-fontawesome": "^0.2 || ^3",
    "@mui/icons-material": "^5 || ^6 || ^7",
    "@mui/material": "^5 || ^6 || ^7",
    "@mui/x-data-grid": "^6 || ^7",
    "@mui/x-date-pickers": "^6 || ^7",
    "axios": "^1",
    "dayjs": "^1",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.6",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "@mui/x-data-grid": "^6.20.4",
    "@mui/x-date-pickers": "^6.20.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0"
  },
  "dependencies": {
    "axios": "^1",
    "dayjs": "^1"
  },
  "keywords": [
    "reports",
    "salescode",
    "react",
    "npm-package"
  ],
  "license": "MIT"
}
